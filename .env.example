# Gmail Configuration for Nodemailer
# Step 1: Enable 2-Factor Authentication on your Gmail account
# Step 2: Go to Google Account Settings > Security > 2-Step Verification > App passwords
# Step 3: Generate an "App Password" for "Mail"
# Step 4: Use that 16-character password below (NOT your regular Gmail password)

# Your Gmail address
EMAIL_USER=your-gmail@gmail.com

# Your Gmail App Password (16 characters, no spaces)
EMAIL_PASS=your-app-password-here

# Where to receive consultation emails (can be same as EMAIL_USER)
EMAIL_RECIPIENT=your-business-email@gmail.com

# Server port
PORT=3000
VITE_BUSINESS_EMAIL=your-business-email@example.com
